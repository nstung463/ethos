# Open Terminal Configuration
OPEN_TERMINAL_API_KEY=your-random-secret-key-change-me
OPEN_TERMINAL_URL=http://localhost:8000
ETHOS_TERMINAL_NAME=Ethos Sandbox
ETHOS_MANAGED_FILES_DIR=./workspace/managed_files

# LLM Provider Configuration
ETHOS_PROVIDER=openrouter
ETHOS_MODEL=openai/gpt-4o-mini

# API Keys (choose one provider)
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxx

# Or Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# Or OpenAI
# OPENAI_API_KEY=sk-xxx

# Optional: Multiple Models Registry (JSON array)
# ETHOS_MODEL_REGISTRY=[{"id":"ethos","provider":"openrouter","model":"openai/gpt-4o-mini"}]
