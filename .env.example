# =============================================================================
# LLM selection
# =============================================================================
# ETHOS_PROVIDER:
# - Native providers: anthropic | openai | google_genai | bedrock | azure_openai
# - Friendly aliases: gemini -> google_genai, amazon -> bedrock, azure -> azure_openai
# - OpenAI-compatible aliases: openrouter | deepseek | together | groq | xai | fireworks | perplexity
ETHOS_PROVIDER=anthropic

# ETHOS_MODEL:
# - For native providers: provider model id (no provider prefix), e.g. claude-sonnet-4-6, gpt-4o
# - Gemini alias/native: gemini-2.5-pro, gemini-2.5-flash, ...
# - Bedrock alias/native: model id on Bedrock, e.g. anthropic.claude-3-5-sonnet-20240620-v1:0
# - Azure alias/native: usually your Azure OpenAI deployment/model name
# - For aliases: model id supported by that provider endpoint, e.g. deepseek-chat, openai/gpt-4o-mini
ETHOS_MODEL=claude-sonnet-4-6

# =============================================================================
# API keys - native providers
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Azure OpenAI (required when ETHOS_PROVIDER=azure or azure_openai)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# AWS Bedrock (required when ETHOS_PROVIDER=amazon or bedrock)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1

# =============================================================================
# API keys - OpenAI-compatible aliases
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
GROQ_API_KEY=your_groq_api_key_here
XAI_API_KEY=your_xai_api_key_here
FIREWORKS_API_KEY=your_fireworks_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# =============================================================================
# Optional endpoint overrides (usually not needed)
# =============================================================================
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# TOGETHER_BASE_URL=https://api.together.xyz/v1
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# XAI_BASE_URL=https://api.x.ai/v1
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# =============================================================================
# Web tools
# =============================================================================
# Required only when using ethos.tools.web.search
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# Sandbox backend
# =============================================================================
# Required only when running with --daytona mode
DAYTONA_API_KEY=your_daytona_api_key_here

# =============================================================================
# Workspace
# =============================================================================
ETHOS_WORKSPACE=./workspace
